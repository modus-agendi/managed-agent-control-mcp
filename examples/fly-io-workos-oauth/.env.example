# Config for the WorkOS AuthKit + Fly.io example.
#
# These map 1:1 to `fly secrets set …` in the README. You can also use this file
# to run the server locally against WorkOS for testing:
#   cp .env.example .env && set -a && . ./.env && set +a
#   uv run python -m managed_agents_mcp --http   (from the repo root)

# Outbound: your Anthropic key with Managed Agents access. SECRET.
ANTHROPIC_API_KEY=sk-ant-...

# Inbound auth: validate WorkOS-issued JWTs. No Cognito, no facade.
MCP_AUTH_MODE=oidc

# Your AuthKit domain (WorkOS Dashboard → Domains → AuthKit). Staging gives a
# default *-staging.authkit.app domain; confirm issuer + jwks_uri with:
#   curl -s $MCP_OIDC_ISSUER/.well-known/oauth-authorization-server | jq '{issuer,jwks_uri}'
MCP_OIDC_ISSUER=https://your-slug-staging.authkit.app
MCP_OIDC_JWKS_URL=https://your-slug-staging.authkit.app/oauth2/jwks

# The token audience = the Resource Indicator you register in WorkOS, which must
# equal your public MCP endpoint URL.
MCP_OIDC_AUDIENCE=https://fib-mcp.fly.dev/mcp

# Public URL clients reach (so OAuth discovery advertises the right host).
MCP_PUBLIC_URL=https://fib-mcp.fly.dev

# Optional guardrail (OFF by default — every agent is allowed). To restrict this
# connector to specific agents, activate the allowlist AND list the agent(s):
# MCP_ALLOWLIST_AGENTS_ACTIVE=true
# MCP_ALLOWED_AGENT_IDS=agent_01...
