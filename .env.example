# Copy to .env and fill in. .env is gitignored; only .env.example is tracked.
# For local stdio runs, only ANTHROPIC_API_KEY is required.

# ─── Outbound: how this server calls the Claude Managed Agents API ────────────

# REQUIRED. Your Anthropic API key. The operator's key — every MCP user of this
# deployment acts within this key's workspace (single-tenant; see docs).
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Override for self-hosted gateways or a local test server.
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional. Pinned API + beta versions. Defaults match the docs; override only
# if Anthropic bumps the Managed Agents beta.
# ANTHROPIC_VERSION=2023-06-01
# MANAGED_AGENTS_BETA=managed-agents-2026-04-01

# ─── Inbound: how MCP clients authenticate TO this server (HTTP only) ─────────
# Stdio runs need none of this — auth is the transport boundary there.
# MCP_AUTH_MODE is a comma-separated list; modes coexist (a JWT-shaped token is
# tried against OIDC, otherwise the static bearer is checked).

# MCP_AUTH_MODE=bearer            # bearer | oidc | cognito (e.g. "oidc,bearer")

# -- bearer mode --
# MCP_BEARER_TOKEN=change-me-to-a-long-random-secret

# -- oidc mode (any OIDC provider: Auth0, Okta, Keycloak, Entra, Cognito) --
# MCP_OIDC_ISSUER=https://your-issuer.example.com
# MCP_OIDC_AUDIENCE=your-app-client-id          # comma-separated list accepted
# MCP_OIDC_JWKS_URL=https://your-issuer.example.com/.well-known/jwks.json
# MCP_OIDC_ALLOWED_PRINCIPALS=                  # optional sub/email allow-list
# MCP_OIDC_REQUIRE_TOKEN_USE=                   # e.g. "access" to reject ID tokens (Cognito)

# -- cognito mode (oidc + hosted-UI OAuth facade for Claude.ai connectors) --
# MCP_COGNITO_HOSTED_UI=https://your-prefix.auth.<region>.amazoncognito.com

# Public base URL advertised in OAuth discovery metadata. Set when a proxy /
# CDN / custom domain fronts this server (its own hostname differs from public).
# MCP_PUBLIC_URL=https://mcp.example.com

# ─── Guardrails (optional; all unset = no restriction) ────────────────────────

# Agent allowlist. OFF by default: every agent is allowed. Set
# MCP_ALLOWLIST_AGENTS_ACTIVE=true to turn it on, then only the agents in
# MCP_ALLOWED_AGENT_IDS may be launched (bounds the blast radius of a
# prompt-injected client spinning up arbitrary token-burning agents).
# MCP_ALLOWLIST_AGENTS_ACTIVE=true
# MCP_ALLOWED_AGENT_IDS=agent_01...,agent_02...

# Comma-separated environment IDs sessions may use. Unset → any environment.
# MCP_ALLOWED_ENVIRONMENT_IDS=env_01...

# When "false", session_archive and session_delete refuse. Default "true".
# MCP_ALLOW_DESTRUCTIVE=true
