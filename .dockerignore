dist
build
*.egg-info
__pycache__
*.py[cod]
.pytest_cache
.ruff_cache
.mypy_cache
.pyright
htmlcov
.coverage
.coverage.*
coverage.xml
.playwright-mcp
.env
.env.*
tests
docs
examples
deploy/aws-lambda
.claude
.DS_Store
